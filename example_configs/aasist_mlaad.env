# ================================
# experiment
# ================================
EXPERIMENT__NAME=aasist_mlaad
EXPERIMENT__OUTPUT_DIR=outputs
EXPERIMENT__SEED=1234
EXPERIMENT__COMMENT=

# ================================
# data
# ================================
DATA__DATASET_NAME=MLAAD
DATA__DATABASE_PATH=/absolute/path/to/mlaad
DATA__PROTOCOLS_PATH=/absolute/path/to/mlaad/protocols
DATA__TRAIN_PROTOCOL=protocol_MLAAD_MAILabs_train.txt
DATA__DEV_PROTOCOL=protocol_MLAAD_MAILabs_dev.txt
DATA__SAMPLING_RATE=16000
DATA__TRAIN_AUDIO_MAX_SAMPLES=192000
DATA__EVAL_AUDIO_MAX_SAMPLES=192000
DATA__PROTOCOL_DELIMITER= 
DATA__PROTOCOL_KEY_COLUMN=0
DATA__PROTOCOL_SRC_COLUMN=3
DATA__PROTOCOL_LABEL_COLUMN=4
DATA__RAWBOOST__ALGO=5
DATA__RAWBOOST__NBANDS=5
DATA__RAWBOOST__MINF=20
DATA__RAWBOOST__MAXF=8000
DATA__RAWBOOST__MINBW=100
DATA__RAWBOOST__MAXBW=1000
DATA__RAWBOOST__MINCOEFF=10
DATA__RAWBOOST__MAXCOEFF=100
DATA__RAWBOOST__MING=0
DATA__RAWBOOST__MAXG=0
DATA__RAWBOOST__MINBIASLINNONLIN=5
DATA__RAWBOOST__MAXBIASLINNONLIN=20
DATA__RAWBOOST__N_F=5
DATA__RAWBOOST__P=10
DATA__RAWBOOST__G_SD=2
DATA__RAWBOOST__SNRMIN=10
DATA__RAWBOOST__SNRMAX=40

# ================================
# model
# ================================
MODEL__FRONTEND=wavlm_large
MODEL__FREEZE_SSL=true
MODEL__FRONTEND_FEATURE_MODE=featurizer
MODEL__FRONTEND_LAYER_INDEX=-1
MODEL__BACKEND=aasist
MODEL__BACKEND_CONFIG=configs/models/aasist.json
MODEL__LOSS=weighted_cce
MODEL__FOCAL_GAMMA=2.0

# ================================
# training
# ================================
TRAINING__MODE=train
TRAINING__DEVICE=cuda:0
TRAINING__BATCH_SIZE=14
TRAINING__EPOCHS=50
TRAINING__NUM_WORKERS=8
TRAINING__CLASS_WEIGHT=[0.1, 0.9]
TRAINING__CUDNN_DETERMINISTIC_TOGGLE=true
TRAINING__CUDNN_BENCHMARK_TOGGLE=false

# ================================
# evaluation
# ================================
EVALUATION__CHECKPOINT=
EVALUATION__SAVE_SCORE_FILE=true
EVALUATION__SCORE_FILE_NAME=eval_score.txt
